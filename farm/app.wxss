/**app.wxss**/
page {
  background-color: #F9F6F0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #5C5C5C;
  line-height: 1.6;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
}

.bg-main {
  background-color: #F9F6F0;
}

.bg-green {
  background-color: #7CBD89;
}

.bg-earth {
  background-color: #B9A385;
}

.text-main {
  color: #5C5C5C;
}

.text-green {
  color: #7CBD89;
}

.text-earth {
  color: #B9A385;
}

.text-price {
  color: #D6543A;
  font-weight: 600;
}

.text-bold {
  font-weight: 600;
}

.text-lg {
  font-size: 32rpx;
}

.text-xl {
  font-size: 36rpx;
}

.text-22 {
  font-size: 44rpx;
  font-weight: 600;
}

.text-center {
  text-align: center;
}

.text-del {
  text-decoration: line-through;
}

.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

.gap-10 {
  gap: 20rpx;
}

.gap-20 {
  gap: 40rpx;
}

.mt-10 {
  margin-top: 20rpx;
}

.mt-20 {
  margin-top: 40rpx;
}

.mt-30 {
  margin-top: 60rpx;
}

.mb-10 {
  margin-bottom: 20rpx;
}

.mb-20 {
  margin-bottom: 40rpx;
}

.p-20 {
  padding: 40rpx;
}

.p-30 {
  padding: 60rpx;
}

.px-20 {
  padding-left: 40rpx;
  padding-right: 40rpx;
}

.py-20 {
  padding-top: 40rpx;
  padding-bottom: 40rpx;
}

.rounded {
  border-radius: 16rpx;
}

.rounded-full {
  border-radius: 50%;
}

.shadow {
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.btn-large {
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  border-radius: 48rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #7CBD89 0%, #5BA86D 100%);
  color: #fff;
  border: none;
}

.btn-earth {
  background: linear-gradient(135deg, #B9A385 0%, #A68B6A 100%);
  color: #fff;
  border: none;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
}

.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

.van-card {
  background: #fff !important;
  border-radius: 16rpx !important;
  margin: 20rpx !important;
}

.van-button--round {
  border-radius: 48rpx !important;
}