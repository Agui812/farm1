<view class="add-address-page">
  <view class="content-wrap">
    <view class="form-card">
      <van-cell-group>
        <van-field
          value="{{ form.name }}"
          label="收货人"
          placeholder="请输入收货人姓名"
          maxlength="20"
          bind:change="onFieldChange"
          data-field="name"
        />
        <van-field
          value="{{ form.phone }}"
          label="手机号"
          type="number"
          placeholder="请输入手机号"
          maxlength="11"
          bind:change="onFieldChange"
          data-field="phone"
        />
        <van-cell title="省市区" is-link bindtap="openAreaPicker" value="{{ form.region || '请选择省市区' }}" value-class="{{ form.region ? '' : 'placeholder' }}"/>
        <van-field
          value="{{ form.detail }}"
          label="详细地址"
          placeholder="请输入详细地址，如街道、门牌号"
          maxlength="100"
          bind:change="onFieldChange"
          data-field="detail"
        />
      </van-cell-group>
    </view>

    <view class="default-card">
      <view class="default-row">
        <text class="default-label">设为默认地址</text>
        <van-switch
          checked="{{ form.is_default === 1 }}"
          size="44rpx"
          active-color="#7CBD89"
          bind:change="onDefaultChange"
        />
      </view>
    </view>

    <view class="save-btn-wrap">
      <van-button type="primary" round size="large" custom-class="save-btn" bindclick="saveAddress">
        保存地址
      </van-button>
    </view>
  </view>

  <van-popup show="{{ showAreaPicker }}" position="bottom" bind:close="closeAreaPicker">
    <van-area
      area-list="{{ areaList }}"
      value="{{ areaValue }}"
      bind:confirm="onAreaConfirm"
      bind:cancel="closeAreaPicker"
    />
  </van-popup>

  <van-toast id="van-toast"/>
</view>