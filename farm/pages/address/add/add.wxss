.add-address-page {
  background-color: #F9F6F0;
  min-height: 100vh;
}

.content-wrap {
  padding: 24rpx;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.default-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 48rpx;
}

.default-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.default-label {
  font-size: 30rpx;
  color: #3C3C3C;
}

.save-btn-wrap {
  margin-top: 60rpx;
}

.save-btn {
  background-color: #7CBD89 !important;
  border-color: #7CBD89 !important;
  font-size: 32rpx;
}

.placeholder {
  color: #BDBDBD !important;
}