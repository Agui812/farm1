.address-page {
  background-color: #F9F6F0;
  min-height: 100vh;
  padding: 24rpx 30rpx;
  padding-bottom: 200rpx;
}

.address-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.address-item {
  padding: 30rpx;
}

.item-main {
  margin-bottom: 24rpx;
}

.item-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.item-user {
  font-size: 32rpx;
  font-weight: 500;
  color: #3C3C3C;
}

.item-address {
  font-size: 26rpx;
  color: #6C6C6C;
  line-height: 1.6;
}

.item-actions {
  display: flex;
  gap: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F5;
}

.action-edit, .action-delete {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #6C6C6C;
}

.action-delete {
  color: #D6543A;
}

.add-btn-wrap {
  position: fixed;
  bottom: 60rpx;
  left: 30rpx;
  right: 30rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 96rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  background: linear-gradient(135deg, #7CBD89 0%, #5BA86D 100%);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 30rpx rgba(124, 189, 137, 0.4);
}

.form-popup {
  background: #fff;
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.form-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #3C3C3C;
}

.form-body {
  padding: 30rpx;
}

.set-default {
  padding: 30rpx 0;
}

.form-btns {
  display: flex;
  gap: 24rpx;
  padding-top: 20rpx;
}

.btn-cancel {
  flex: 1;
  height: 88rpx !important;
  line-height: 88rpx !important;
  font-size: 30rpx !important;
  border-radius: 44rpx !important;
  background: #F5F5F5 !important;
  color: #6C6C6C !important;
  border: none !important;
}

.btn-save {
  flex: 1;
  height: 88rpx !important;
  line-height: 88rpx !important;
  font-size: 30rpx !important;
  border-radius: 44rpx !important;
  background: linear-gradient(135deg, #7CBD89 0%, #5BA86D 100%) !important;
  border: none !important;
}