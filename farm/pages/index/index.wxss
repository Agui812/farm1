.index-page {
  background: linear-gradient(180deg, #F5F7FA 0%, #F9F6F0 20%, #F9F6F0 100%);
  min-height: 100vh;
  position: relative;
}

.index-page::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(135deg, rgba(124, 189, 137, 0.08) 0%, rgba(91, 168, 109, 0.04) 100%);
  pointer-events: none;
}

.banner-section {
  width: 100%;
  position: relative;
}

.banner-swiper {
  width: 100%;
  height: 400rpx;
}

.banner-swiper::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60rpx;
  background: linear-gradient(180deg, transparent 0%, #F5F7FA 100%);
  pointer-events: none;
}

.slogan-section {
  padding: 48rpx 30rpx 40rpx;
  text-align: center;
  background: linear-gradient(180deg, #F5F7FA 0%, transparent 100%);
  position: relative;
}

.slogan-section::after {
  content: '';
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #7CBD89 0%, #5BA86D 100%);
  border-radius: 2rpx;
}

.slogan-text {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #7CBD89 0%, #5BA86D 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 16rpx;
  letter-spacing: 6rpx;
  animation: fadeInUp 0.6s ease-out;
}

.slogan-sub {
  font-size: 26rpx;
  color: #9C9C9C;
  letter-spacing: 2rpx;
  animation: fadeInUp 0.6s ease-out 0.1s both;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.recommend-section {
  padding: 30rpx;
  animation: fadeInUp 0.6s ease-out 0.2s both;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  position: relative;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #3C3C3C;
  position: relative;
  padding-left: 24rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #7CBD89 0%, #5BA86D 100%);
  border-radius: 4rpx;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #7CBD89;
  font-weight: 500;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(124, 189, 137, 0.08);
  transition: all 0.3s ease;
}

.section-more:active {
  background: rgba(124, 189, 137, 0.15);
}

.goods-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.goods-card {
  padding: 0;
  overflow: hidden;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.goods-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.goods-info {
  padding: 24rpx;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #3C3C3C;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-price {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.price-current {
  font-size: 36rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #D6543A 0%, #C44430 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.price-original {
  font-size: 24rpx;
  color: #BDBDBD;
  text-decoration: line-through;
}

.farm-section {
  margin: 30rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #F9F6F0 100%);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
  animation: fadeInUp 0.6s ease-out 0.3s both;
}

.farm-section::before {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(124, 189, 137, 0.1) 0%, transparent 70%);
  pointer-events: none;
}

.farm-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.farm-title {
  flex: 1;
}

.farm-name {
  font-size: 34rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #7CBD89 0%, #5BA86D 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.farm-desc {
  font-size: 24rpx;
  color: #9C9C9C;
  margin-top: 4rpx;
}

.farm-desc-full {
  font-size: 28rpx;
  color: #6C6C6C;
  line-height: 1.8;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.farm-tags {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  position: relative;
  z-index: 1;
}

.contact-section {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 30rpx;
  margin: 30rpx;
  gap: 100rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #F9F6F0 100%);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  animation: fadeInUp 0.6s ease-out 0.4s both;
}

.contact-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #6C6C6C;
  font-weight: 500;
  padding: 20rpx 30rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.contact-item:active {
  background: rgba(124, 189, 137, 0.08);
  transform: scale(0.95);
}

.contact-divider {
  width: 2rpx;
  height: 80rpx;
  background: linear-gradient(180deg, transparent 0%, #E5E5E5 50%, transparent 100%);
}

.bottom-safe {
  height: calc(env(safe-area-inset-bottom) + 120rpx);
}