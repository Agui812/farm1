.order-detail-page {
  background-color: #F9F6F0;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.order-status-card {
  display: flex;
  align-items: center;
  gap: 30rpx;
  padding: 50rpx 30rpx;
  background: linear-gradient(135deg, #7CBD89 0%, #5BA86D 100%);
}

.status-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-info {
  flex: 1;
}

.status-text {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.status-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.address-section, .goods-section, .info-section {
  margin: 24rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3C3C3C;
  margin-bottom: 24rpx;
}

.address-user {
  font-size: 30rpx;
  font-weight: 500;
  color: #3C3C3C;
  margin-bottom: 12rpx;
}

.address-detail {
  font-size: 26rpx;
  color: #6C6C6C;
  line-height: 1.6;
}

.goods-item {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 0;
}

.goods-item:not(:last-child) {
  border-bottom: 1rpx solid #F5F5F5;
  margin-bottom: 16rpx;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #3C3C3C;
}

.goods-spec {
  font-size: 24rpx;
  color: #9C9C9C;
  margin-top: 8rpx;
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.goods-price {
  font-size: 30rpx;
  font-weight: 500;
  color: #D6543A;
}

.goods-num {
  font-size: 26rpx;
  color: #6C6C6C;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-row:not(:last-child) {
  border-bottom: 1rpx solid #F5F5F5;
}

.info-label {
  font-size: 26rpx;
  color: #6C6C6C;
}

.info-value {
  font-size: 26rpx;
  color: #3C3C3C;
}

.info-value.price {
  font-size: 36rpx;
  font-weight: 600;
  color: #D6543A;
}

.logistics-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.logistics-company {
  font-size: 28rpx;
  font-weight: 600;
  color: #3C3C3C;
}

.logistics-no {
  font-size: 24rpx;
  color: #6C6C6C;
}

.logistics-timeline {
  padding-left: 20rpx;
}

.timeline-item {
  display: flex;
  gap: 20rpx;
  padding-bottom: 24rpx;
  position: relative;
}

.timeline-item:not(:last-child)::before {
  content: '';
  position: absolute;
  left: 11rpx;
  top: 28rpx;
  bottom: 0;
  width: 2rpx;
  background: #E5E5E5;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #E5E5E5;
  flex-shrink: 0;
  margin-top: 4rpx;
  position: relative;
  z-index: 1;
}

.timeline-dot.active {
  background: #7CBD89;
  box-shadow: 0 0 0 4rpx rgba(124, 189, 137, 0.2);
}

.timeline-content {
  flex: 1;
}

.timeline-time {
  font-size: 22rpx;
  color: #9C9C9C;
  margin-bottom: 6rpx;
}

.timeline-desc {
  font-size: 26rpx;
  color: #3C3C3C;
  line-height: 1.5;
}

.timeline-item:first-child .timeline-desc {
  color: #7CBD89;
  font-weight: 500;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-bottom: 0;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.bar-actions {
  display: flex;
  gap: 16rpx;
}

.btn-cancel, .btn-receive, .btn-contact {
  height: 64rpx !important;
  line-height: 64rpx !important;
  font-size: 26rpx !important;
  padding: 0 24rpx !important;
}

.btn-cancel {
  background: #F5F5F5 !important;
  color: #6C6C6C !important;
  border: none !important;
}

.btn-receive {
  background: linear-gradient(135deg, #7CBD89 0%, #5BA86D 100%) !important;
  color: #fff !important;
  border: none !important;
}

.btn-contact {
  background: #F5F5F5 !important;
  color: #6C6C6C !important;
  border: none !important;
}

.btn-pay {
  height: 72rpx !important;
  line-height: 72rpx !important;
  font-size: 28rpx !important;
  padding: 0 40rpx !important;
  background: linear-gradient(135deg, #D6543A 0%, #C44430 100%) !important;
  border: none !important;
}

.bottom-safe {
  height: calc(env(safe-area-inset-bottom) + 20rpx);
}