<view class="confirm-page">
  <view class="address-section card" bindtap="selectAddress">
    <view class="address-empty" wx:if="{{!address}}">
      <van-icon name="plus" size="48rpx" color="#7CBD89"/>
      <text>添加收货地址</text>
    </view>
    <view class="address-info" wx:else>
      <view class="address-main">
        <view class="address-user">{{address.name}} {{address.phone}}</view>
        <view class="address-detail">{{address.region}}{{address.detail}}</view>
      </view>
      <van-icon name="arrow" size="36rpx" color="#BDBDBD"/>
    </view>
  </view>

  <view class="goods-section card">
    <view class="section-title">商品清单</view>
    <view class="goods-item" wx:for="{{goodsList}}" wx:key="index">
      <van-image width="140rpx" height="140rpx" src="{{item.image}}" fit="cover" radius="12rpx"/>
      <view class="goods-info">
        <view class="goods-name">{{item.name}}</view>
        <view class="goods-spec">{{item.spec || '默认'}}</view>
        <view class="goods-bottom">
          <view class="goods-price">¥{{item.price}}</view>
          <view class="goods-num">x{{item.num}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="delivery-section card" wx:if="{{!isPointGoods}}">
    <view class="section-title">配送方式</view>
    <van-radio-group value="{{deliveryType}}" bind:change="onDeliveryChange">
      <view class="delivery-item">
        <van-radio name="1" checked="{{deliveryType === 1}}" checked-color="#7CBD89">
          <view class="delivery-name">快递配送</view>
          <view class="delivery-desc">预计3-5个工作日送达</view>
        </van-radio>
      </view>
      <view class="delivery-item">
        <van-radio name="2" checked="{{deliveryType === 2}}" checked-color="#7CBD89">
          <view class="delivery-name">上门自提</view>
          <view class="delivery-desc">到农场自取，节省运费</view>
        </van-radio>
      </view>
    </van-radio-group>
  </view>

  <view class="price-section card">
    <view class="price-row">
      <text class="price-label">商品金额</text>
      <text class="price-value">¥{{goodsAmount}}</text>
    </view>
    <view class="price-row" wx:if="{{isVip}}">
      <text class="price-label vip-label">会员立减</text>
      <text class="price-value vip-discount">-¥{{vipDiscount}}</text>
    </view>
    <view class="price-row" wx:if="{{isVip}}">
      <text class="price-label vip-label">会员包邮</text>
      <text class="price-value vip-discount">已减免</text>
    </view>
    <view class="price-row" wx:else>
      <text class="price-label">运费</text>
      <text class="price-value">{{freight > 0 ? '¥' + freight : '免运费'}}</text>
    </view>
    <view class="price-row total-row" wx:if="{{!isPointGoods}}">
      <text class="price-label">合计</text>
      <text class="price-total">¥{{totalAmount}}</text>
    </view>
    <view class="price-row total-row" wx:else>
      <text class="price-label">消耗积分</text>
      <text class="price-total points-total">{{pointGoods.points}} 积分</text>
    </view>
  </view>

  <view class="bottom-safe"></view>

  <view class="bottom-bar" style="padding-bottom: 0px;">
    <view class="total-info" wx:if="{{!isPointGoods}}">
      <text class="total-label">实付款：</text>
      <text class="total-price">¥{{totalAmount}}</text>
    </view>
    <view class="total-info" wx:else>
      <text class="total-label">消耗积分：</text>
      <text class="total-price points-price">{{pointGoods.points}} 积分</text>
    </view>
    <view class="submit-btn" bindtap="submitOrder">{{isPointGoods ? '提交兑换' : '提交订单'}}</view>
  </view>
</view>