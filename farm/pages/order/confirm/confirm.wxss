.confirm-page {
  background-color: #F9F6F0;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.address-section {
  margin: 24rpx;
  padding: 30rpx;
}

.address-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 30rpx;
  font-size: 30rpx;
  color: #7CBD89;
}

.address-info {
  display: flex;
  align-items: center;
}

.address-main {
  flex: 1;
}

.address-user {
  font-size: 32rpx;
  font-weight: 500;
  color: #3C3C3C;
  margin-bottom: 12rpx;
}

.address-detail {
  font-size: 26rpx;
  color: #6C6C6C;
  line-height: 1.6;
}

.goods-section {
  margin: 24rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3C3C3C;
  margin-bottom: 24rpx;
}

.goods-item {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 0;
}

.goods-item:not(:last-child) {
  border-bottom: 1rpx solid #F5F5F5;
  margin-bottom: 16rpx;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #3C3C3C;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-spec {
  font-size: 24rpx;
  color: #9C9C9C;
  margin-top: 8rpx;
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.goods-price {
  font-size: 30rpx;
  font-weight: 500;
  color: #D6543A;
}

.goods-num {
  font-size: 26rpx;
  color: #6C6C6C;
}

.delivery-section {
  margin: 24rpx;
  padding: 30rpx;
}

.delivery-item {
  padding: 20rpx 0;
}

.delivery-name {
  font-size: 28rpx;
  color: #3C3C3C;
}

.delivery-desc {
  font-size: 22rpx;
  color: #9C9C9C;
  margin-top: 4rpx;
}

.price-section {
  margin: 24rpx;
  padding: 30rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.price-label {
  font-size: 28rpx;
  color: #6C6C6C;
}

.price-value {
  font-size: 28rpx;
  color: #3C3C3C;
}

.vip-label {
  color: #D4A017;
}

.vip-discount {
  color: #D6543A;
  font-weight: 500;
}

.total-row {
  border-top: 1rpx solid #F5F5F5;
  margin-top: 8rpx;
  padding-top: 24rpx;
}

.total-row .price-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #3C3C3C;
}

.price-total {
  font-size: 40rpx;
  font-weight: 600;
  color: #D6543A;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.total-info {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #6C6C6C;
}

.total-price {
  font-size: 44rpx;
  font-weight: 600;
  color: #D6543A;
}

.points-total,
.points-price {
  color: #FF6034;
}

.submit-btn {
  width: 240rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  background: linear-gradient(135deg, #7CBD89 0%, #5BA86D 100%);
  border-radius: 44rpx;
}

.bottom-safe {
  height: calc(env(safe-area-inset-bottom) + 140rpx);
}