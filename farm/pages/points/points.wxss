.points-page {
  background-color: #F9F6F0;
  min-height: 100vh;
  padding: 30rpx;
}

.points-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #7CBD89 0%, #5DAE6F 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.points-balance {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.balance-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.balance-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.sign-btn-wrap {
  display: flex;
  align-items: center;
}

.points-rule {
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.rule-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #3C3C3C;
  margin-bottom: 24rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.rule-item:last-child {
  margin-bottom: 0;
}

.rule-item text {
  font-size: 26rpx;
  color: #6C6C6C;
}

.exchange-section {
  margin-bottom: 30rpx;
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.goods-item {
  display: flex;
  padding: 20rpx;
}

.goods-item .van-image {
  flex-shrink: 0;
}

.goods-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  margin-left: 20rpx;
}

.goods-item .goods-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #3C3C3C;
  margin-bottom: 8rpx;
}

.goods-stock {
  font-size: 24rpx;
  color: #9C9C9C;
  margin-bottom: 8rpx;
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-item .goods-points {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 0;
}

.goods-item .goods-points text {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF6034;
}

.history-section {
  margin-bottom: 30rpx;
}

.history-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-type {
  font-size: 28rpx;
  color: #3C3C3C;
}

.history-time {
  font-size: 22rpx;
  color: #9C9C9C;
}

.history-points {
  font-size: 32rpx;
  font-weight: 600;
}

.history-points.positive {
  color: #7CBD89;
}

.history-points.negative {
  color: #FF6034;
}

.history-empty {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
}

.history-empty text {
  font-size: 26rpx;
  color: #9C9C9C;
}

.bottom-safe {
  height: calc(env(safe-area-inset-bottom) + 60rpx);
}