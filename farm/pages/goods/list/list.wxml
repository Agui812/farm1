<view class="goods-list-page">
  <view class="search-bar">
    <van-search value="{{keyword}}" placeholder="搜索商品" bind:search="onSearch" bind:change="onSearchChange"/>
  </view>

  <view class="category-tabs">
    <van-tabs active="{{ activeCategory }}" bind:change="onCategoryChange">
      <van-tab title="全部" name="all"></van-tab>
      <van-tab title="大米" name="rice"></van-tab>
      <van-tab title="粗粮" name="grain"></van-tab>
      <van-tab title="干货" name="dry"></van-tab>
      <van-tab title="其他" name="other"></van-tab>
    </van-tabs>
  </view>

  <scroll-view scroll-y class="goods-scroll" bindscrolltolower="loadMore">
    <view class="goods-grid">
      <view class="goods-card" wx:for="{{goodsList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <van-image width="100%" height="340rpx" src="{{item.image}}" fit="cover" radius="16rpx 16rpx 0 0"/>
        <view class="goods-info">
          <view class="goods-name">{{item.name}}</view>
          <view class="goods-desc">{{item.desc}}</view>
          <view class="goods-bottom">
            <view class="goods-price">
              <text class="price-symbol">¥</text>
              <text class="price-value">{{item.min_price || item.price}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="loading-tip" wx:if="{{loading}}">
      <van-loading>加载中...</van-loading>
    </view>
    <view class="no-more" wx:if="{{noMore && goodsList.length > 0}}">
      <text>没有更多了</text>
    </view>
    <view class="empty-tip" wx:if="{{!loading && goodsList.length === 0}}">
      <text>暂无商品</text>
    </view>
  </scroll-view>

  <view class="bottom-safe"></view>
</view>